# ─── Database — Supabase ──────────────────────────────────────────────────────
# Pooled connection (PgBouncer) — used by the app at runtime
DATABASE_URL=postgresql://postgres:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Direct connection — used by Alembic migrations (DDL doesn't work with pooler)
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ─── External APIs ────────────────────────────────────────────────────────────
OPEN_METEO_URL=https://api.open-meteo.com
OSRM_URL=http://router.project-osrm.org

# ─── Pipeline ─────────────────────────────────────────────────────────────────
RISK_THRESHOLD=0.65
DEMO_MODE=false

# ─── AI Agent (post-MVP) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
